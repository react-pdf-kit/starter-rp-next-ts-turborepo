{
	"name": "starter-rp-next-ts-turborepo",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev --filter=web",
		"lint": "turbo run lint",
		"format": "prettier --write \"**/*.{ts,tsx,md}\"",
		"check-types": "turbo run check-types"
	},
	"devDependencies": {
		"prettier": "^3.5.3",
		"turbo": "^2.8.13",
		"typescript": "5.8.2"
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "npm@11.11.0",
	"workspaces": [
		"apps/*",
		"packages/*"
	]
}
